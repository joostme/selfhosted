{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "assignees": ["joostme"],
  "labels": ["renovate"],
  "configMigration": true,
  "prHourlyLimit": 0,
  "docker-compose": {
    "packageRules": [
      {
        "matchPackageNames": ["ghcr.io/immich-app/postgres"],
        "enabled": false
      },
      {
        "matchPackageNames": ["getmeili/meilisearch"],
        "enabled": false
      },
      {
        "matchPackageNames": ["codeberg.org/forgejo/forgejo"],
        "registryUrls": ["https://codeberg.org"],
        "sourceUrl": "https://codeberg.org/forgejo/forgejo",
        "changelogUrl": "https://codeberg.org/forgejo/forgejo/releases"
      },
      {
        "matchPackageNames": ["ghcr.io/toniebox-reverse-engineering/teddycloud"],
        "versioning": "regex:^tc_v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
        "sourceUrl": "https://github.com/toniebox-reverse-engineering/teddycloud",
        "changelogUrl": "https://github.com/toniebox-reverse-engineering/teddycloud/releases"
      },
      {
        "matchPackageNames": ["ghcr.io/imagegenius/immich"],
        "sourceUrl": "https://github.com/immich-app/immich",
        "changelogUrl": "https://github.com/immich-app/immich/releases"
      },
      {
        "matchPackageNames": ["jellyfin/jellyfin"],
        "sourceUrl": "https://github.com/jellyfin/jellyfin",
        "changelogUrl": "https://github.com/jellyfin/jellyfin/releases"
      }
    ]
  }
}

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "assignees": ["joostme"],
  "labels": ["renovate"],
  "configMigration": true,
  "prHourlyLimit": 0,
  "docker-compose": {
    "packageRules": [
      {
        "matchPackageNames": ["ghcr.io/immich-app/postgres"],
        "enabled": false
      },
      {
        "matchPackageNames": ["getmeili/meilisearch"],
        "enabled": false
      },
      {
        "matchPackageNames": ["codeberg.org/forgejo/forgejo"],
        "registryUrls": ["https://codeberg.org"],
        "sourceUrl": "https://codeberg.org/forgejo/forgejo",
        "changelogUrl": "https://codeberg.org/forgejo/forgejo/releases"
      },
      {
        "matchPackageNames": ["ghcr.io/toniebox-reverse-engineering/teddycloud"],
        "versioning": "regex:^tc_v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
        "sourceUrl": "https://github.com/toniebox-reverse-engineering/teddycloud",
        "changelogUrl": "https://github.com/toniebox-reverse-engineering/teddycloud/releases"
      },
      {
        "matchPackageNames": ["ghcr.io/imagegenius/immich"],
        "sourceUrl": "https://github.com/immich-app/immich",
        "changelogUrl": "https://github.com/immich-app/immich/releases"
      },
      {
        "matchPackageNames": ["ghcr.io/hotio/prowlarr"],
        "versioning": "regex:^release-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$"
      },
      {
        "matchPackageNames": ["jellyfin/jellyfin"],
        "sourceUrl": "https://github.com/jellyfin/jellyfin",
        "changelogUrl": "https://github.com/jellyfin/jellyfin/releases"
      },
      {
        "matchPackageNames": ["linuxserver/radarr"],
        "sourceUrl": "https://github.com/Radarr/Radarr",
        "changelogUrl": "https://github.com/Radarr/Radarr/releases"
      },
      {
        "matchPackageNames": ["linuxserver/sonarr"],
        "sourceUrl": "https://github.com/Sonarr/Sonarr",
        "changelogUrl": "https://github.com/Sonarr/Sonarr/releases"
      },
      {
        "matchPackageNames": ["linuxserver/sabnzbd"],
        "sourceUrl": "https://github.com/sabnzbd/sabnzbd",
        "changelogUrl": "https://github.com/sabnzbd/sabnzbd/releases"
      },
      {
        "matchPackageNames": ["lscr.io/linuxserver/syncthing"],
        "sourceUrl": "https://github.com/syncthing/syncthing",
        "changelogUrl": "https://github.com/syncthing/syncthing/releases"
      },
      {
        "matchPackageNames": ["/^(?:lscr\\.io/)?linuxserver\/.+$/"],
        "sourceUrl": "https://github.com/linuxserver/docker-{{replace '^(?:lscr\\.io/)?linuxserver/' '' packageName}}",
        "changelogUrl": "https://github.com/linuxserver/docker-{{replace '^(?:lscr\\.io/)?linuxserver/' '' packageName}}/releases"
      }
    ]
  }
}
